meta {
  name: Get eSIM 5 Details
  type: http
  seq: 5
}

get {
  url: {{baseUrl}}/sims/{{iccid5}}
  body: none
  auth: bearer
}


auth:bearer {
  token: {{accessToken}}
}

headers {
  Accept: application/json
}

script:pre-request {
  const token = bru.getEnvVar("accessToken");
  if (!token) {
    throw new Error("accessToken is empty. Run 01-auth/get-access-token first.");
  }
  const iccid = bru.getEnvVar("iccid5");
  if (!iccid) {
    throw new Error("iccid5 is empty. Run 02-orders/submit-order first.");
  }
}

tests {
  test("Status 200 - OK", function () {
    expect(res.status).to.equal(200);
  });

  test("Response has meta object", function () {
    expect(res.body).to.have.property("meta");
    expect(res.body.meta).to.have.property("message");
  });

  test("Response has data object", function () {
    expect(res.body).to.have.property("data");
    expect(res.body.data).to.be.an("object");
  });

  test("ICCID matches the requested eSIM", function () {
    expect(res.body.data.iccid).to.equal(bru.getEnvVar("iccid5"));
  });

  test("ICCID has valid format (18–22 digits)", function () {
    expect(res.body.data.iccid).to.match(/^\d{18,22}$/);
  });

  test("eSIM has an LPA activation code", function () {
    expect(res.body.data).to.have.property("lpa");
    expect(res.body.data.lpa).to.be.a("string").and.not.empty;
  });

  test("eSIM has a matching_id", function () {
    expect(res.body.data).to.have.property("matching_id");
    expect(res.body.data.matching_id).to.be.a("string").and.not.empty;
  });

  test("eSIM has a QR code", function () {
    expect(res.body.data).to.have.property("qrcode");
    expect(res.body.data.qrcode).to.be.a("string").and.not.empty;
  });

  test("eSIM has a QR code URL", function () {
    expect(res.body.data).to.have.property("qrcode_url");
    expect(res.body.data.qrcode_url).to.be.a("string").and.not.empty;
  });

  test("eSIM has direct_apple_installation_url field", function () {
    expect(res.body.data).to.have.property("direct_apple_installation_url");
  });

  test("eSIM has is_roaming boolean field", function () {
    expect(res.body.data).to.have.property("is_roaming");
    expect(res.body.data.is_roaming).to.be.a("boolean");
  });
}
