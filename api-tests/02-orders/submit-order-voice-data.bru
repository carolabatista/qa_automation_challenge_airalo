meta {
  name: Submit Order - 200 Voice and Data Package
  type: http
  seq: 6
}

post {
  url: {{baseUrl}}/orders
  body: multipartForm
  auth: bearer
}

auth:bearer {
  token: {{accessToken}}
}

headers {
  Accept: application/json
}

body:multipart-form {
  quantity: 1
  package_id: {{voiceDataPackageId}}
  type: sim
}

script:pre-request {
  const token = bru.getEnvVar("accessToken");
  if (!token) {
    throw new Error("accessToken is empty. Run 01-auth/get-access-token first.");
  }
}

tests {
  test("Status 200 - OK", function () {
    expect(res.status).to.equal(200);
  });

  test("meta.message equals 'success'", function () {
    expect(res.body).to.have.property("meta");
    expect(res.body.meta.message).to.equal("success");
  });

  test("Response has data object", function () {
    expect(res.body).to.have.property("data");
    expect(res.body.data).to.be.an("object");
  });

  test("Order has text field (Voice and Data package property)", function () {
    expect(res.body.data).to.have.property("text");
  });

  test("Order has voice field (Voice and Data package property)", function () {
    expect(res.body.data).to.have.property("voice");
  });

  test("Order has net_price field", function () {
    expect(res.body.data).to.have.property("net_price");
  });

  test("sims array is present and non-empty", function () {
    expect(res.body.data.sims).to.be.an("array");
    expect(res.body.data.sims.length).to.be.greaterThan(0);
  });

  test("Each eSIM has an ICCID", function () {
    res.body.data.sims.forEach(function (sim) {
      expect(sim.iccid).to.match(/^\d{18,22}$/);
    });
  });

  test("Each eSIM has a QR code", function () {
    res.body.data.sims.forEach(function (sim) {
      expect(sim).to.have.property("qrcode");
      expect(sim.qrcode).to.be.a("string").and.not.empty;
    });
  });

  test("Each eSIM has an msisdn field (Voice and Data eSIM property)", function () {
    res.body.data.sims.forEach(function (sim) {
      expect(sim).to.have.property("msisdn");
    });
  });

  test("Each eSIM has an apn object with ios and android sub-objects", function () {
    res.body.data.sims.forEach(function (sim) {
      expect(sim).to.have.property("apn");
      expect(sim.apn).to.be.an("object");
      expect(sim.apn).to.have.property("ios");
      expect(sim.apn).to.have.property("android");
    });
  });
}

