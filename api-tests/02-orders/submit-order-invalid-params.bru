meta {
  name: Submit Order - 422 Invalid Package ID
  type: http
  seq: 2
}

post {
  url: {{baseUrl}}/orders
  body: multipartForm
  auth: bearer
}

auth:bearer {
  token: {{accessToken}}
}

headers {
  Accept: application/json
}

body:multipart-form {
  quantity: 1
  package_id: this-package-does-not-exist
  type: sim
}

script:pre-request {
  const token = bru.getEnvVar("accessToken");
  if (!token) {
    throw new Error("accessToken is empty. Run 01-auth/get-access-token first.");
  }
}

tests {
  test("Status 422 - Unprocessable Entity", function () {
    expect(res.status).to.equal(422);
  });

  test("Response has a numeric error code", function () {
    expect(res.body).to.have.property("code");
    expect(res.body.code).to.be.a("number");
  });

  test("Response has a reason string describing the error", function () {
    expect(res.body).to.have.property("reason");
    expect(res.body.reason).to.be.a("string").and.not.empty;
  });
}

