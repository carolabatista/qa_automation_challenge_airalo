meta {
  name: Submit Order - 422 Invalid Package ID
  type: http
  seq: 2
}

post {
  url: {{baseUrl}}/orders
  body: multipartForm
  auth: bearer
}

auth:bearer {
  token: {{accessToken}}
}

headers {
  Accept: application/json
}

body:multipart-form {
  quantity: 1
  package_id: this-package-does-not-exist
  type: sim
}

script:pre-request {
  const token = bru.getEnvVar("accessToken");
  if (!token) {
    throw new Error("accessToken is empty. Run 01-auth/get-access-token first.");
  }
}

tests {
  test("Status 422 - Unprocessable Entity", function () {
    expect(res.status).to.equal(422);
  });

  test("meta.message is 'the parameter is invalid'", function () {
    expect(res.body).to.have.property("meta");
    expect(res.body.meta.message).to.equal("the parameter is invalid");
  });

  test("Response body contains package_id validation error", function () {
    expect(res.body).to.have.property("data");
    expect(res.body.data).to.be.an("object");
    expect(res.body.data).to.have.property("package_id");
    expect(res.body.data.package_id).to.be.a("string").and.not.empty;
  });
}

