meta {
  name: Submit Order - 422 SIM Quantity Not Available
  type: http
  seq: 4
}

post {
  url: {{baseUrl}}/orders
  body: multipartForm
  auth: bearer
}

auth:bearer {
  token: {{accessToken}}
}

headers {
  Accept: application/json
}

body:multipart-form {
  quantity: 50
  package_id: {{packageId}}
  type: sim
}

script:pre-request {
  const token = bru.getEnvVar("accessToken");
  if (!token) {
    throw new Error("accessToken is empty. Run 01-auth/get-access-token first.");
  }
}

tests {
  // Stock levels in production are not under test control — quantity: 50 may succeed
  // if the package has sufficient stock, or return 422 when stock is exhausted.
  // Both outcomes are valid and tested: 200 (stock available) or 422 (quantity not available).

  test("API responds with 200 or 422", function () {
    expect([200, 422]).to.include(res.status);
  });

  test("200: meta.message is 'success' and sims array is non-empty", function () {
    if (res.status === 200) {
      expect(res.body.meta.message).to.equal("success");
      expect(res.body.data.sims).to.be.an("array").and.have.length.greaterThan(0);
    }
  });

  test("422: meta.message is 'the parameter is invalid'", function () {
    if (res.status === 422) {
      expect(res.body).to.have.property("meta");
      expect(res.body.meta.message).to.equal("the parameter is invalid");
    }
  });

  test("422: data.quantity contains the stock availability error message", function () {
    if (res.status === 422) {
      expect(res.body).to.have.property("data");
      expect(res.body.data).to.have.property("quantity");
      expect(res.body.data.quantity).to.be.a("string").and.not.empty;
    }
  });
}

