meta {
  name: Submit Order - 6 eSIMs
  type: http
  seq: 1
}

post {
  url: {{baseUrl}}/orders
  body: multipartForm
  auth: bearer
}

auth:bearer {
  token: {{accessToken}}
}

headers {
  Accept: application/json
}

body:multipart-form {
  quantity: {{quantity}}
  package_id: {{packageId}}
  type: sim
}

script:pre-request {
  const token = bru.getEnvVar("accessToken");
  if (!token) {
    throw new Error("accessToken is empty. Run 01-auth/get-access-token first.");
  }
}

script:post-response {
  if (res.status === 200 && res.body.data && res.body.data.sims) {
    const sims = res.body.data.sims;
    sims.forEach((sim, index) => {
      bru.setEnvVar(`iccid${index + 1}`, sim.iccid);
    });
    console.log(`✓ Order placed. ${sims.length} eSIMs obtained.`);
    console.log("ICCIDs:", sims.map(s => s.iccid).join(", "));
  } else {
    throw new Error(
      `Failed to place order. Status: ${res.status}. Body: ${JSON.stringify(res.body)}`
    );
  }
}

tests {
  // ── HTTP + envelope ─────────────────────────────────────────────────────────
  test("Status 200 - OK", function () {
    expect(res.status).to.equal(200);
  });

  test("Response has meta.message 'success'", function () {
    expect(res.body).to.have.property("meta");
    expect(res.body.meta.message).to.equal("success");
  });

  test("Response has data object", function () {
    expect(res.body).to.have.property("data");
    expect(res.body.data).to.be.an("object");
  });

  // ── Order-level fields ───────────────────────────────────────────────────────
  test("Order has a numeric ID", function () {
    expect(res.body.data).to.have.property("id");
    expect(res.body.data.id).to.be.a("number").and.greaterThan(0);
  });

  test("Order has a code string", function () {
    expect(res.body.data).to.have.property("code");
    expect(res.body.data.code).to.be.a("string").and.not.empty;
  });

  test("Order type is 'sim'", function () {
    expect(res.body.data.type).to.equal("sim");
  });

  test("Order quantity in response is 6", function () {
    expect(Number(res.body.data.quantity)).to.equal(6);
  });

  test("Order currency is present", function () {
    expect(res.body.data).to.have.property("currency");
    expect(res.body.data.currency).to.be.a("string").and.not.empty;
  });

  test("Package ID matches requested package", function () {
    expect(res.body.data.package_id).to.equal("moshi-moshi-7days-1gb");
  });

  test("esim_type is a non-empty string", function () {
    expect(res.body.data).to.have.property("esim_type");
    expect(res.body.data.esim_type).to.be.a("string").and.not.empty;
  });

  test("validity is a positive integer", function () {
    expect(res.body.data).to.have.property("validity");
    expect(res.body.data.validity).to.be.a("number").and.greaterThan(0);
  });

  test("package name is a non-empty string", function () {
    expect(res.body.data).to.have.property("package");
    expect(res.body.data.package).to.be.a("string").and.not.empty;
  });

  test("data allowance is a non-empty string", function () {
    expect(res.body.data).to.have.property("data");
    expect(res.body.data.data).to.be.a("string").and.not.empty;
  });

  test("price is a positive number", function () {
    expect(res.body.data).to.have.property("price");
    expect(res.body.data.price).to.be.a("number").and.greaterThan(0);
  });

  test("pricing_model is a non-empty string", function () {
    expect(res.body.data).to.have.property("pricing_model");
    expect(res.body.data.pricing_model).to.be.a("string").and.not.empty;
  });

  test("manual_installation is a non-empty string", function () {
    expect(res.body.data).to.have.property("manual_installation");
    expect(res.body.data.manual_installation).to.be.a("string").and.not.empty;
  });

  test("qrcode_installation is a non-empty string", function () {
    expect(res.body.data).to.have.property("qrcode_installation");
    expect(res.body.data.qrcode_installation).to.be.a("string").and.not.empty;
  });

  test("installation_guides has at least one language key", function () {
    expect(res.body.data).to.have.property("installation_guides");
    expect(res.body.data.installation_guides).to.be.an("object");
    expect(Object.keys(res.body.data.installation_guides).length).to.be.greaterThan(0);
  });

  // ── sims array ───────────────────────────────────────────────────────────────
  test("Order contains 6 eSIMs", function () {
    expect(res.body.data.sims).to.be.an("array");
    expect(res.body.data.sims).to.have.lengthOf(6);
  });

  test("All ICCIDs are unique", function () {
    const iccids = res.body.data.sims.map(sim => sim.iccid);
    const unique = new Set(iccids);
    expect(unique.size).to.equal(iccids.length);
  });

  test("Each ICCID has valid format (18–22 digits)", function () {
    res.body.data.sims.forEach(function (sim) {
      expect(sim.iccid).to.match(/^\d{18,22}$/);
    });
  });

  test("Each eSIM has an LPA activation code", function () {
    res.body.data.sims.forEach(function (sim) {
      expect(sim).to.have.property("lpa");
      expect(sim.lpa).to.be.a("string").and.not.empty;
    });
  });

  test("Each eSIM has a matching_id", function () {
    res.body.data.sims.forEach(function (sim) {
      expect(sim).to.have.property("matching_id");
      expect(sim.matching_id).to.be.a("string").and.not.empty;
    });
  });

  test("Each eSIM has a QR code", function () {
    res.body.data.sims.forEach(function (sim) {
      expect(sim).to.have.property("qrcode");
      expect(sim.qrcode).to.be.a("string").and.not.empty;
    });
  });

  test("Each eSIM has a QR code URL", function () {
    res.body.data.sims.forEach(function (sim) {
      expect(sim).to.have.property("qrcode_url");
      expect(sim.qrcode_url).to.be.a("string").and.not.empty;
    });
  });

  test("Each eSIM has a direct Apple installation URL", function () {
    res.body.data.sims.forEach(function (sim) {
      expect(sim).to.have.property("direct_apple_installation_url");
      expect(sim.direct_apple_installation_url).to.be.a("string").and.not.empty;
    });
  });

  test("Each eSIM has an apn_type field", function () {
    res.body.data.sims.forEach(function (sim) {
      expect(sim).to.have.property("apn_type");
    });
  });

  test("Each eSIM has an is_roaming boolean", function () {
    res.body.data.sims.forEach(function (sim) {
      expect(sim).to.have.property("is_roaming");
      expect(sim.is_roaming).to.be.a("boolean");
    });
  });
}

